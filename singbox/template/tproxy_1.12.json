      "tag": "HK",
      "type": "urltest",
      "outbounds": [
        "{all}"
      ],
      "url": "https://cp.cloudflare.com",
      "interval": "60s",
      "tolerance": 300,
      "filter": [
        {
          "action": "match",
          "regex": [
            "(?i)^(?=.*(🇭🇰|HK|hk|香港|hongkong))(?!.*(家宽|isp|小众)).*$"
          ]
        }
      ]
    },
    {
